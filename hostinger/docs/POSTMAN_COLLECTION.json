        { "name": "Verify OTP", "request": { "method": "POST", "url": "{{base_url}}/otp/verify", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"phone\":\"+8801700000000\",\"code\":\"123456\",\"purpose\":\"login\"}" } } },
        { "name": "SMS Log (Admin)", "request": { "method": "GET", "url": "{{base_url}}/admin/sms/log?page=1", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } }
      ]
