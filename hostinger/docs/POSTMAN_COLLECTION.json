{
  "info": {
    "name": "Artistiya PHP Backend API v2.0",
    "description": "Complete API collection for Artistiya e-commerce — PHP/MySQL backend. 100+ endpoints across 19 folders: Auth, Products, Orders, Payments, Delivery, Email, SMS, OTP, Custom Orders, Invoices, CRM, Content, Cart, Reviews, Promos, Newsletter, Storage, Settings, Health.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "artistiya-php-api-v2"
  },
  "variable": [
    { "key": "base_url", "value": "https://yourdomain.com/api", "type": "string" },
    { "key": "jwt_token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01. Authentication",
      "item": [
        { "name": "Register", "request": { "method": "POST", "url": "{{base_url}}/auth/register", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"email\":\"test@example.com\",\"password\":\"SecurePass123!\",\"full_name\":\"Test User\"}" } } },
        { "name": "Login", "event": [{ "listen": "test", "script": { "exec": ["var r=pm.response.json();if(r.token)pm.collectionVariables.set('jwt_token',r.token);"] } }], "request": { "method": "POST", "url": "{{base_url}}/auth/login", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"email\":\"test@example.com\",\"password\":\"SecurePass123!\"}" } } },
        { "name": "Admin Login", "event": [{ "listen": "test", "script": { "exec": ["var r=pm.response.json();if(r.token)pm.collectionVariables.set('admin_token',r.token);"] } }], "request": { "method": "POST", "url": "{{base_url}}/auth/login", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"email\":\"admin@artistiya.store\",\"password\":\"AdminPass123!\"}" } } },
        { "name": "Get Profile", "request": { "method": "GET", "url": "{{base_url}}/auth/profile" } },
        { "name": "Update Profile", "request": { "method": "PUT", "url": "{{base_url}}/auth/profile", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"full_name\":\"Updated Name\",\"phone\":\"+8801700000000\"}" } } },
        { "name": "Change Password", "request": { "method": "POST", "url": "{{base_url}}/auth/change-password", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"current_password\":\"OldPass123!\",\"new_password\":\"NewPass456!\"}" } } },
        { "name": "Forgot Password", "request": { "method": "POST", "url": "{{base_url}}/auth/forgot-password", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"email\":\"test@example.com\"}" } } },
        { "name": "Reset Password", "request": { "method": "POST", "url": "{{base_url}}/auth/reset-password", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"token\":\"reset-token\",\"new_password\":\"NewPass789!\"}" } } },
        { "name": "Logout", "request": { "method": "POST", "url": "{{base_url}}/auth/logout" } }
      ]
    },
    {
      "name": "02. Products",
      "item": [
        { "name": "List Products", "request": { "method": "GET", "url": "{{base_url}}/products?page=1&limit=20&sort=created_at&order=desc" } },
        { "name": "Get Product", "request": { "method": "GET", "url": "{{base_url}}/products/:id" } },
        { "name": "Search Products", "request": { "method": "GET", "url": "{{base_url}}/products/search?q=handmade&category=jewelry" } },
        { "name": "Create Product (Admin)", "request": { "method": "POST", "url": "{{base_url}}/admin/products", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] }, "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"name\":\"Handmade Vase\",\"price\":2500,\"category_id\":\"cat-id\",\"description\":\"Beautiful ceramic vase\",\"stock_quantity\":10}" } } },
        { "name": "Update Product (Admin)", "request": { "method": "PUT", "url": "{{base_url}}/admin/products/:id", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] }, "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"price\":2800,\"stock_quantity\":15}" } } },
        { "name": "Delete Product (Admin)", "request": { "method": "DELETE", "url": "{{base_url}}/admin/products/:id", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } },
        { "name": "Bulk Upload (Admin)", "request": { "method": "POST", "url": "{{base_url}}/admin/products/bulk-upload", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] }, "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "products.csv" }] } } },
        { "name": "Export CSV (Admin)", "request": { "method": "GET", "url": "{{base_url}}/admin/products/export?format=csv", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } }
      ]
    },
    {
      "name": "03. Categories",
      "item": [
        { "name": "List Categories", "request": { "method": "GET", "url": "{{base_url}}/categories" } },
        { "name": "Get Category", "request": { "method": "GET", "url": "{{base_url}}/categories/:slug" } },
        { "name": "Create (Admin)", "request": { "method": "POST", "url": "{{base_url}}/admin/categories", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] }, "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"name\":\"Jewelry\",\"slug\":\"jewelry\"}" } } },
        { "name": "Export CSV", "request": { "method": "GET", "url": "{{base_url}}/admin/categories/export?format=csv", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } },
        { "name": "Import CSV", "request": { "method": "POST", "url": "{{base_url}}/admin/categories/import", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] }, "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "categories.csv" }] } } }
      ]
    },
    {
      "name": "04. Orders",
      "item": [
        { "name": "Create Order", "request": { "method": "POST", "url": "{{base_url}}/orders", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"address_id\":\"addr-id\",\"payment_method\":\"cod\",\"items\":[{\"product_id\":\"prod-id\",\"quantity\":2}]}" } } },
        { "name": "My Orders", "request": { "method": "GET", "url": "{{base_url}}/orders/my" } },
        { "name": "Order Detail", "request": { "method": "GET", "url": "{{base_url}}/orders/:id" } },
        { "name": "Track Order", "request": { "method": "GET", "url": "{{base_url}}/orders/track/:orderNumber" } },
        { "name": "List (Admin)", "request": { "method": "GET", "url": "{{base_url}}/admin/orders?status=pending&page=1", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } },
        { "name": "Update Status (Admin)", "request": { "method": "PUT", "url": "{{base_url}}/admin/orders/:id/status", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] }, "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"status\":\"shipped\",\"tracking_number\":\"TRK123\"}" } } },
        { "name": "Export CSV (Admin)", "request": { "method": "GET", "url": "{{base_url}}/admin/orders/export?format=csv", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } },
        { "name": "Export Excel (Admin)", "request": { "method": "GET", "url": "{{base_url}}/admin/orders/export?format=xlsx", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } }
      ]
    },
    {
      "name": "05. Payments",
      "item": [
        { "name": "SSLCommerz Init", "request": { "method": "POST", "url": "{{base_url}}/payments/sslcommerz/init", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"order_id\":\"order-id\",\"amount\":5000}" } } },
        { "name": "SSLCommerz IPN", "request": { "method": "POST", "url": "{{base_url}}/payments/sslcommerz/ipn" } },
        { "name": "bKash Create", "request": { "method": "POST", "url": "{{base_url}}/payments/bkash/create", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"order_id\":\"order-id\",\"amount\":5000}" } } },
        { "name": "bKash Execute", "request": { "method": "POST", "url": "{{base_url}}/payments/bkash/execute", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"paymentID\":\"PAY123\"}" } } },
        { "name": "Nagad Init", "request": { "method": "POST", "url": "{{base_url}}/payments/nagad/init", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"order_id\":\"order-id\",\"amount\":5000}" } } },
        { "name": "aamarPay Init", "request": { "method": "POST", "url": "{{base_url}}/payments/aamarpay/init", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"order_id\":\"order-id\",\"amount\":5000}" } } },
        { "name": "SurjoPay Init", "request": { "method": "POST", "url": "{{base_url}}/payments/surjopay/init", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"order_id\":\"order-id\",\"amount\":5000}" } } },
        { "name": "Providers (Admin)", "request": { "method": "GET", "url": "{{base_url}}/admin/payment-providers", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } },
        { "name": "Update Provider (Admin)", "request": { "method": "PUT", "url": "{{base_url}}/admin/payment-providers/:id", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] }, "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"is_active\":true}" } } }
      ]
    },
    {
      "name": "06. Email System",
