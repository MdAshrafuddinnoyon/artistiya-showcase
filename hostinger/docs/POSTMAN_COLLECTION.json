        { "name": "Shipping Update", "request": { "method": "POST", "url": "{{base_url}}/email/shipping-update", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"order_id\":\"order-id\"}" } } },
        { "name": "Delivery Notification", "request": { "method": "POST", "url": "{{base_url}}/email/delivery-notification", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"order_id\":\"order-id\"}" } } },
        { "name": "Templates (Admin)", "request": { "method": "GET", "url": "{{base_url}}/admin/email/templates", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}" }] } } },
